---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Try the Demo — Forj AI Call Answering"
  description="Call our live AI agent and experience exactly what your customers will hear. Then get started for $199/mo."
>

  <!-- Header -->
  <section class="bg-[#0A1628] text-white py-16 md:py-20 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <div class="inline-block bg-[#2D6FE8]/20 text-[#2D6FE8] text-sm font-semibold px-4 py-1.5 rounded-full mb-6 border border-[#2D6FE8]/30">
        Live Demo
      </div>
      <h1 class="text-4xl md:text-5xl font-black mb-4">Hear It For Yourself</h1>
      <p class="text-white/70 text-lg">Call our demo line and experience exactly what your customers will hear — live, right now.</p>
    </div>
  </section>

  <!-- Demo call section -->
  <section class="py-16 px-4 bg-white border-b border-gray-100">
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-gray-500 text-sm uppercase tracking-wider font-semibold mb-4">Demo Line</p>
      <a href="tel:+12029050261" class="inline-flex items-center gap-3 text-4xl md:text-5xl font-black text-[#0A1628] hover:text-[#2D6FE8] transition-colors mb-6">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-[#2D6FE8]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.948V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        (202) 905-0261
      </a>
      <p class="text-gray-400 text-sm mb-8">Available 24/7 — call anytime, it always picks up</p>

      <div class="grid md:grid-cols-3 gap-6 text-left max-w-2xl mx-auto">
        {[
          { n: "1", title: "Call the number", desc: "The AI agent answers immediately. No wait, no hold music." },
          { n: "2", title: "Have a real conversation", desc: "Ask about services, pricing, availability — whatever a real customer would ask." },
          { n: "3", title: "See how it qualifies you", desc: "Notice how it collects your info and scores the call. That's what your leads will experience." },
        ].map(step => (
          <div class="flex gap-3">
            <span class="bg-[#2D6FE8] text-white text-sm font-black w-7 h-7 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">{step.n}</span>
            <div>
              <p class="font-bold text-[#0A1628] mb-1">{step.title}</p>
              <p class="text-gray-500 text-sm">{step.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Get started form -->
  <section class="py-20 px-4 bg-white">
    <div class="max-w-5xl mx-auto grid md:grid-cols-2 gap-16 items-start">

      <!-- Left: Form -->
      <div>
        <h2 class="text-2xl font-black text-[#0A1628] mb-2">Ready to get started?</h2>
        <p class="text-gray-500 mb-8">Tell us about your business and we'll get your AI agent configured and live within days.</p>

        <iframe
          data-tally-src="https://tally.so/embed/jaE6L6?alignLeft=1&hideTitle=1&dynamicHeight=1"
          loading="lazy"
          width="100%"
          height="400"
          frameborder="0"
          marginheight="0"
          marginwidth="0"
        ></iframe>
      </div>

      <!-- Right: What to expect -->
      <div class="space-y-8">
        <div class="bg-gray-50 rounded-2xl p-8">
          <h3 class="text-xl font-black text-[#0A1628] mb-6">What happens next</h3>
          <ol class="space-y-5">
            {[
              { n: "1", title: "We reach out within 1 business day", desc: "Quick call to understand your business, your services, and how you qualify leads." },
              { n: "2", title: "We configure your AI agent", desc: "Custom script, your agent's name, qualification questions — built for your specific business." },
              { n: "3", title: "We connect it to your number", desc: "Forward your business line or get a new one. Live in days, not weeks." },
              { n: "4", title: "Leads start coming in", desc: "Every call answered, scored, and waiting for you in your dashboard when you're ready." },
            ].map(step => (
              <li class="flex gap-4">
                <span class="bg-[#2D6FE8] text-white text-sm font-black w-7 h-7 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">{step.n}</span>
                <div>
                  <p class="font-bold text-[#0A1628]">{step.title}</p>
                  <p class="text-gray-500 text-sm">{step.desc}</p>
                </div>
              </li>
            ))}
          </ol>
        </div>

        <div class="bg-[#0A1628] rounded-2xl p-8 text-white">
          <h3 class="text-xl font-black mb-4">Get in touch directly</h3>
          <div class="space-y-4">
            <a href="mailto:james@forjahead.com" class="flex items-center gap-3 text-white/80 hover:text-white transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-[#2D6FE8]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              james@forjahead.com
            </a>
            <a href="tel:+12029050261" class="flex items-center gap-3 text-white/80 hover:text-white transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-[#2D6FE8]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.948V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              (202) 905-0261
            </a>
          </div>
        </div>
      </div>

    </div>
  </section>

</Layout>
