---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Get Started — Forj AI Call Answering"
  description="Tell us about your business and we'll reach out to get your AI agent set up. Live in days, not weeks."
>

  <!-- Header -->
  <section class="bg-[#0A1628] text-white py-16 md:py-20 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <h1 class="text-4xl md:text-5xl font-black mb-4">Get Started</h1>
      <p class="text-white/70 text-lg">Call us, fill out the form, or email directly. We'll get your AI agent live within days.</p>
    </div>
  </section>

  <!-- Form section -->
  <section class="py-20 px-4 bg-white">
    <div class="max-w-5xl mx-auto grid md:grid-cols-2 gap-16 items-start">

      <!-- Left: Form -->
      <div>
        <h2 class="text-2xl font-black text-[#0A1628] mb-2">Tell us about your business</h2>
        <p class="text-gray-500 mb-8">We'll get back to you within 1 business day.</p>

        <iframe
          data-tally-src="https://tally.so/embed/jaE6L6?alignLeft=1&hideTitle=1&dynamicHeight=1"
          loading="lazy"
          width="100%"
          height="400"
          frameborder="0"
          marginheight="0"
          marginwidth="0"
        ></iframe>
      </div>

      <!-- Right: What happens next -->
      <div class="space-y-8">
        <div class="bg-gray-50 rounded-2xl p-8">
          <h3 class="text-xl font-black text-[#0A1628] mb-6">What happens next</h3>
          <ol class="space-y-5">
            {[
              { n: "1", title: "We reach out within 1 business day", desc: "A quick conversation to understand your business, your services, and how you qualify leads." },
              { n: "2", title: "We configure your AI agent", desc: "Custom script, your agent's name, qualification questions — built specifically for your business." },
              { n: "3", title: "We connect it to your number", desc: "Forward your business line or get a new one. Live in days, not weeks." },
              { n: "4", title: "Leads start coming in", desc: "Every call answered, scored, and waiting in your dashboard. You follow up when you're ready." },
            ].map(step => (
              <li class="flex gap-4">
                <span class="bg-[#2D6FE8] text-white text-sm font-black w-7 h-7 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">{step.n}</span>
                <div>
                  <p class="font-bold text-[#0A1628]">{step.title}</p>
                  <p class="text-gray-500 text-sm">{step.desc}</p>
                </div>
              </li>
            ))}
          </ol>
        </div>

        <div class="bg-[#0A1628] rounded-2xl p-8 text-white">
          <h3 class="text-xl font-black mb-4">Prefer to reach out directly?</h3>
          <div class="space-y-4">
            <a href="tel:+12407166820" class="flex items-center gap-3 text-white/80 hover:text-white transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-[#2D6FE8]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.948V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              (240) 716-6820 — talk to our AI agent
            </a>
            <a href="mailto:james@forjahead.com" class="flex items-center gap-3 text-white/80 hover:text-white transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-[#2D6FE8]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              james@forjahead.com
            </a>
          </div>
        </div>
      </div>

    </div>
  </section>

</Layout>
