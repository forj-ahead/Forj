---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="About Forj — AI Call Answering for Small Businesses"
  description="Forj builds AI receptionists for local service businesses. Answer every call, qualify every lead, and never lose a customer to voicemail again."
>

  <section class="bg-[#0A1628] text-white py-16 md:py-20 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <h1 class="text-4xl md:text-5xl font-black mb-4">About Forj</h1>
      <p class="text-white/70 text-lg">Built for the business owner who's too busy to answer every call.</p>
    </div>
  </section>

  <section class="py-20 px-4 bg-white">
    <div class="max-w-3xl mx-auto">
      <div class="prose prose-lg max-w-none text-gray-600 leading-relaxed space-y-6">
        <p class="text-2xl font-black text-[#0A1628] leading-snug">
          Every missed call is a lead going to your competitor.
        </p>
        <p>
          Forj was built for the landscaper on a job site who can't answer the phone. The roofer whose voicemail is full. The plumber who calls back at 6pm and the customer has already hired someone else.
        </p>
        <p>
          Your AI receptionist answers every call, figures out what the customer needs, and scores the lead so you know exactly who's worth calling back — and who isn't. You get a dashboard with every caller's name, number, what they need, and a score from 1 to 10.
        </p>
        <p>
          One flat fee. Unlimited calls. No long-term contracts. You focus on the work — we make sure no lead slips through.
        </p>
      </div>
    </div>
  </section>

  <section class="py-20 px-4 bg-gray-50">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-3xl font-black text-[#0A1628] mb-12 text-center">How we work</h2>
      <div class="grid md:grid-cols-2 gap-8">
        {[
          {
            title: "Set up once, runs forever",
            desc: "We configure your AI script, set up your phone number, and get your dashboard ready. After that, it just works — no maintenance, no tinkering required."
          },
          {
            title: "Flat pricing, no surprises",
            desc: "$199/month. No per-call fees. No tiers. No nickel-and-diming. Your bill is the same whether you get 10 calls or 500."
          },
          {
            title: "Built around your business",
            desc: "Your AI knows what services you offer, what you don't, and what makes a good lead for you specifically. Not a generic answering service."
          },
          {
            title: "No lock-in",
            desc: "Month-to-month contracts. Cancel with 30 days notice. We earn your business every month because it works — not because you're stuck."
          },
          {
            title: "Real results you can see",
            desc: "Monthly reports show calls answered, leads generated, and how many you've converted. Know exactly what you're getting for your $199."
          },
          {
            title: "Real support",
            desc: "You get a real person when you need help. Not a ticket queue. Fast responses and someone who actually knows your setup."
          }
        ].map(item => (
          <div class="bg-white rounded-2xl p-7 shadow-sm">
            <h3 class="text-xl font-bold text-[#0A1628] mb-2">{item.title}</h3>
            <p class="text-gray-500 leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-[#0A1628] text-white py-16 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl md:text-4xl font-black mb-4">Never miss a qualified lead again.</h2>
      <p class="text-white/70 text-lg mb-8">$199/month. Setup in days. No contracts.</p>
      <a href="/contact" class="inline-block bg-[#2D6FE8] text-white font-black text-lg px-10 py-4 rounded-xl hover:bg-blue-600 hover:ring-2 hover:ring-[#2D6FE8] transition-all shadow-xl">
        Get Started →
      </a>
    </div>
  </section>

</Layout>
