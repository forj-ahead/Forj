---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="About Forj — AI Call Answering for Local Businesses"
  description="Forj's AI answers every call, qualifies leads instantly, and keeps your pipeline full so you never miss a customer again."
>

  <!-- Header -->
  <section class="bg-[#0A1628] text-white py-16 md:py-20 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <h1 class="text-4xl md:text-5xl font-black mb-4">About Forj</h1>
      <p class="text-white/70 text-lg">AI that answers calls, qualifies leads, and keeps your pipeline full.</p>
    </div>
  </section>

  <!-- Story -->
  <section class="py-20 px-4 bg-white">
    <div class="max-w-3xl mx-auto">
      <div class="prose prose-lg max-w-none text-gray-600 leading-relaxed space-y-6">
        <p class="text-2xl font-black text-[#0A1628] leading-snug">
          Local businesses lose customers every day to voicemail. We built Forj to fix that.
        </p>
        <p>
          Forj was built for the roofer who misses calls while on the roof. The HVAC company that loses jobs to whoever picks up first. The plumber who can't answer at 9pm when someone's pipe just burst.
        </p>
        <p>
          Our AI agent answers every call — 24/7 — asks the right questions, and scores the lead in real time. When a hot prospect calls, you get an instant alert with everything you need to follow up and close the deal.
        </p>
        <p>
          No per-call fees. No complicated setup. One flat monthly rate. You focus on the work. We make sure you never miss a customer again.
        </p>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="py-20 px-4 bg-gray-50">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-3xl font-black text-[#0A1628] mb-12 text-center">How we work</h2>
      <div class="grid md:grid-cols-2 gap-8">
        {[
          {
            title: "Fully managed setup",
            desc: "We configure your AI agent, write the script, tune the qualification questions, and connect it to your number. You don't touch a thing."
          },
          {
            title: "Transparent pricing",
            desc: "One flat monthly fee. No per-call charges, no usage limits, no surprise bills. $199/mo is what you pay."
          },
          {
            title: "Results over jargon",
            desc: "We don't talk about 'AI pipelines' or 'conversational interfaces.' We talk about leads, follow-ups, and closed deals. That's what matters."
          },
          {
            title: "No lock-in",
            desc: "Month-to-month contracts. Cancel anytime. We earn your business every month because the product delivers, not because you're stuck."
          },
          {
            title: "Built for inbound calls",
            desc: "We specialize in businesses that live and die by the phone. We know what callers expect and how to qualify them fast."
          },
          {
            title: "Real support",
            desc: "You get a real person, not a ticket queue. Fast response times and someone who actually knows your account."
          }
        ].map(item => (
          <div class="bg-white rounded-2xl p-7 shadow-sm">
            <h3 class="text-xl font-bold text-[#0A1628] mb-2">{item.title}</h3>
            <p class="text-gray-500 leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-[#0A1628] text-white py-16 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl md:text-4xl font-black mb-4">Ready to never miss a lead again?</h2>
      <p class="text-white/80 text-lg mb-8">Get started today — no long-term commitment, no credit card required.</p>
      <a href="/contact" class="inline-block bg-[#2D6FE8] text-white font-black text-lg px-10 py-4 rounded-lg hover:bg-blue-600 hover:ring-2 hover:ring-[#2D6FE8] transition-all shadow-xl">
        Get Started →
      </a>
    </div>
  </section>

</Layout>
