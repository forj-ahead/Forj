---
import Layout from '../layouts/Layout.astro';

const plan = {
  name: "Full Access",
  price: "$199",
  tagline: "Everything you need. Nothing you don't.",
  highlight: true,
  features: [
    "AI agent answers every call, 24/7",
    "Real-time lead qualification & scoring",
    "Instant alerts when a hot lead comes in",
    "Full lead dashboard with call transcripts",
    "Lead notes, status tracking, and pipeline",
    "CSV export for your leads",
    "Monthly performance reports (PDF export)",
    "Unlimited calls — flat rate, no per-call fees",
    "Custom AI agent name & script for your business",
    "Dedicated setup and onboarding support",
  ],
};
---

<Layout
  title="Pricing — Forj"
  description="One flat monthly fee. Forj's AI answers every call, qualifies leads, and keeps your pipeline full for $199/mo."
>

  <!-- Header -->
  <section class="bg-[#0A1628] text-white py-16 md:py-20 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <h1 class="text-4xl md:text-5xl font-black mb-4">Pricing</h1>
      <p class="text-white/70 text-lg">One flat fee. No per-call charges. No hidden costs. Cancel anytime.</p>
    </div>
  </section>

  <!-- Plans -->
  <section class="py-20 px-4 bg-white">
    <div class="max-w-5xl mx-auto">
      <div class="max-w-lg mx-auto">
        <div class="border-2 border-[#2D6FE8] rounded-2xl p-8 relative shadow-2xl">
          <span class="absolute -top-3 left-1/2 -translate-x-1/2 bg-[#2D6FE8] text-white text-xs font-black px-4 py-1 rounded-full">EVERYTHING INCLUDED</span>
          <p class="text-sm font-semibold text-[#2D6FE8] uppercase tracking-wider mb-2">{plan.name}</p>
          <p class="text-4xl font-black text-[#0A1628] mb-1">{plan.price}<span class="text-lg font-normal text-gray-400">/mo</span></p>
          <p class="text-sm text-gray-400 mb-1">Flat rate — no per-call fees, ever</p>
          <p class="text-sm font-medium text-gray-500 mb-7">{plan.tagline}</p>

          <div class="mb-8">
            <p class="text-xs font-bold uppercase tracking-wider mb-3 text-gray-400">What's included</p>
            <ul class="space-y-2.5">
              {plan.features.map(f => (
                <li class="flex gap-2.5 text-sm text-gray-600">
                  <span class="text-[#2D6FE8] font-bold mt-0.5">✓</span>
                  {f}
                </li>
              ))}
            </ul>
          </div>

          <a href="/contact" class="block text-center bg-[#2D6FE8] text-white font-bold py-3 rounded-lg hover:bg-blue-600 transition-colors">
            Get Started
          </a>
        </div>
      </div>

      <p class="text-center text-gray-400 text-sm mt-10">No long-term contracts. No credit card required to get started.</p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-20 px-4 bg-gray-50">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-3xl font-black text-[#0A1628] mb-10 text-center">Common Questions</h2>
      <div class="space-y-6">
        {[
          {
            q: "Is there a long-term contract?",
            a: "No. Month-to-month. Cancel anytime with 30 days notice. We keep clients because the product works, not because we lock them in."
          },
          {
            q: "How quickly can I get set up?",
            a: "Most clients are live within a few days. We handle the setup — configure your AI agent, tune it to your business, and connect it to your number."
          },
          {
            q: "Are there any per-call fees?",
            a: "None. The $199/mo covers everything. No per-minute, per-call, or usage charges. You can handle as many calls as you get."
          },
          {
            q: "What does the AI actually say on the call?",
            a: "We configure a custom script for your business — your agent name, your services, the questions to qualify callers. It sounds natural, not robotic."
          },
          {
            q: "What happens after the AI qualifies a lead?",
            a: "You get an instant alert with the caller's name, number, what they need, and their lead score. You follow up when you're ready — everything is logged in your dashboard."
          },
          {
            q: "What kinds of businesses use Forj?",
            a: "Any business that relies on inbound calls — roofers, HVAC, landscapers, plumbers, law firms, insurance brokers, and more. If the phone rings, we can help."
          }
        ].map(item => (
          <div class="bg-white rounded-xl p-6 shadow-sm">
            <h3 class="font-bold text-[#0A1628] text-lg mb-2">{item.q}</h3>
            <p class="text-gray-500 leading-relaxed">{item.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-[#0A1628] text-white py-16 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl md:text-4xl font-black mb-4">Ready to stop missing leads?</h2>
      <p class="text-white/80 text-lg mb-8">Get started today — we'll have your AI agent configured and live within days.</p>
      <a href="/contact" class="inline-block bg-[#2D6FE8] text-white font-black text-lg px-10 py-4 rounded-lg hover:bg-blue-600 hover:ring-2 hover:ring-[#2D6FE8] transition-all shadow-xl">
        Get Started →
      </a>
    </div>
  </section>

</Layout>
