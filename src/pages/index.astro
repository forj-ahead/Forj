---
import Layout from '../layouts/Layout.astro';
import { Phone, ClipboardList, Zap, BarChart2, Bell, Headphones } from 'lucide-astro';

const services = [
  { title: "AI Answers Every Call", desc: "Your AI agent picks up every call — 24/7, no voicemail, no missed opportunities. Callers get a real conversation, not a robot menu.", Icon: Phone },
  { title: "Instant Lead Qualification", desc: "The AI asks the right questions and scores every caller in real time. You know who's serious before you ever call them back.", Icon: ClipboardList },
  { title: "Instant Alerts", desc: "Hot leads trigger an instant notification with the caller's name, number, what they need, and their score. You're first to follow up.", Icon: Zap },
  { title: "Lead Dashboard", desc: "Every call logged, scored, and organized. Filter by status, see transcripts, track your pipeline — all in one place.", Icon: BarChart2 },
  { title: "Monthly Reporting", desc: "Know exactly how many calls came in, how many qualified, and how fast your team followed up. Real numbers, not guesses.", Icon: Bell },
  { title: "Fully Managed Setup", desc: "We configure your AI agent, tune it to your business, and keep it running. You just answer the good leads.", Icon: Headphones },
];

const industries = ["Roofers","HVAC","Landscapers","Plumbers","Electricians","Movers","Painters","Cleaners","Contractors","Auto Repair","Pest Control","Tree Services","Pressure Washing","Concrete & Masonry","Insurance Brokers","Mortgage Brokers","Independent Financial Advisors","Law Firms"];
---

<Layout
  title="Forj — AI That Answers Your Calls"
  description="Forj's AI answers every call, qualifies leads instantly, and alerts you when a hot prospect is ready. Never miss a customer again."
>

  <!-- Hero -->
  <section class="bg-[#0A1628] text-white pt-10 pb-0 md:pt-14 px-4 overflow-hidden">
    <div class="max-w-6xl mx-auto">
      <div class="flex flex-col md:flex-row md:items-center gap-12 md:gap-16">

        <!-- Left: Text -->
        <div class="md:w-1/2 pb-12 md:pb-20">
          <div class="inline-block bg-[#2D6FE8]/20 text-[#2D6FE8] text-sm font-semibold px-4 py-1.5 rounded-full mb-8 border border-[#2D6FE8]/30">
            AI Call Answering for Local Businesses
          </div>
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-black leading-tight mb-6">
            Never Miss<br />a Qualified<br /><span class="text-[#2D6FE8]">Lead Again.</span>
          </h1>
          <p class="text-white/70 text-lg md:text-xl mb-10 leading-relaxed">
            Forj's AI answers every call, qualifies the lead in real time, and alerts you instantly when a hot prospect is ready. You close the deal. We handle everything else.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="/contact" class="bg-[#2D6FE8] text-white font-black text-lg px-8 py-4 rounded-lg hover:bg-blue-600 hover:ring-2 hover:ring-[#2D6FE8] transition-all shadow-xl text-center">
              Get Started →
            </a>
            <a href="/services" class="border border-white/30 text-white font-semibold text-lg px-8 py-4 rounded-lg hover:bg-white/10 transition-colors text-center">
              See Pricing
            </a>
          </div>
        </div>

        <!-- Right: Browser mockup -->
        <div class="md:w-1/2 flex items-end justify-center md:justify-end">
          <div class="w-full max-w-lg">
            <!-- Browser chrome -->
            <div class="bg-[#1a2a44] rounded-t-xl border border-white/10 px-4 py-3 flex items-center gap-2">
              <div class="flex gap-1.5">
                <div class="w-3 h-3 rounded-full bg-red-400/70"></div>
                <div class="w-3 h-3 rounded-full bg-yellow-400/70"></div>
                <div class="w-3 h-3 rounded-full bg-green-400/70"></div>
              </div>
              <div class="flex-1 mx-3 bg-white/10 rounded-md px-3 py-1 text-xs text-white/40 font-mono">
                acmeroofing.com
              </div>
            </div>
            <!-- Browser content -->
            <div class="bg-white rounded-b-xl overflow-hidden shadow-2xl border border-white/10 border-t-0">
              <!-- Mock site nav -->
              <div class="bg-[#0A1628] px-5 py-3 flex items-center justify-between">
                <div class="text-white font-black text-sm">ACME ROOFING</div>
                <div class="hidden sm:flex gap-4 text-white/60 text-xs">
                  <span>Services</span><span>About</span><span>Contact</span>
                </div>
                <div class="bg-[#2D6FE8] text-white text-xs font-bold px-3 py-1.5 rounded">Call Now</div>
              </div>
              <!-- Mock hero -->
              <div class="bg-gradient-to-br from-slate-700 to-slate-900 px-6 py-8 text-white">
                <div class="text-xs text-white/50 uppercase tracking-widest mb-2">Trusted Local Roofer</div>
                <div class="text-xl font-black mb-2 leading-tight">Licensed, Insured &<br />Ready to Help</div>
                <div class="text-white/60 text-xs mb-4">Family-owned. Fully insured. Since 2008.</div>
                <div class="flex gap-2">
                  <div class="bg-[#2D6FE8] text-white text-xs font-bold px-4 py-2 rounded">Free Estimate</div>
                  <div class="border border-white/30 text-white text-xs px-4 py-2 rounded">Our Work</div>
                </div>
              </div>
              <!-- Mock services -->
              <div class="bg-gray-50 px-6 py-5">
                <div class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-3">Our Services</div>
                <div class="grid grid-cols-3 gap-2">
                  {["Roof Repair","New Roofs","Gutters"].map(s => (
                    <div class="bg-white rounded-lg p-3 text-center shadow-sm border border-gray-100">
                      <div class="text-lg mb-1">🏠</div>
                      <div class="text-xs font-semibold text-gray-700">{s}</div>
                    </div>
                  ))}
                </div>
              </div>
              <!-- Mock reviews -->
              <div class="bg-white px-6 py-4 border-t border-gray-100">
                <div class="flex items-center gap-2 mb-2">
                  <div class="text-yellow-400 text-sm">★★★★★</div>
                  <div class="text-xs font-bold text-gray-700">4.9 · 127 reviews</div>
                </div>
                <div class="text-xs text-gray-400 italic">"Best roofer in DC. Fast, clean, and fairly priced."</div>
              </div>
            </div>
            <!-- Glow effect -->
            <div class="h-6 bg-gradient-to-b from-[#2D6FE8]/20 to-transparent rounded-b-xl blur-sm -mt-1"></div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Social proof bar -->
  <section class="bg-white border-b border-gray-100 py-6 px-4">
    <div class="max-w-5xl mx-auto flex flex-wrap justify-center gap-6 md:gap-10 text-sm text-gray-500 font-medium">
      <span>✓ Answers calls 24/7</span>
      <span>✓ No per-call fees</span>
      <span>✓ Live in days, not weeks</span>
      <span>✓ Full lead dashboard</span>
      <span>✓ Cancel anytime</span>
    </div>
  </section>

  <!-- What we do -->
  <section class="py-20 px-4 bg-white">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-14">
        <h2 class="text-3xl md:text-4xl font-black text-[#0A1628] mb-4">Everything You Need. Nothing You Don't.</h2>
        <p class="text-gray-500 text-lg max-w-xl mx-auto">One flat monthly fee. Your AI agent answers every call, qualifies every lead, and keeps your pipeline full.</p>
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        {services.map(item => (
          <div class="bg-gray-50 rounded-2xl p-7 hover:shadow-md transition-shadow">
            <div class="mb-4">
              <item.Icon size={32} color="#2D6FE8" stroke-width={1.5} />
            </div>
            <h3 class="text-xl font-bold text-[#0A1628] mb-2">{item.title}</h3>
            <p class="text-gray-500 leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Who we serve -->
  <section class="py-20 px-4 bg-gray-50">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-14">
        <h2 class="text-3xl md:text-4xl font-black text-[#0A1628] mb-4">Built for Any Business That Runs on Inbound Calls</h2>
        <p class="text-gray-500 text-lg">If the phone rings and you need to follow up fast, Forj is for you.</p>
      </div>
      <div class="flex flex-wrap justify-center gap-3">
        {industries.map(biz => (
          <span class="bg-white border border-gray-200 text-gray-700 font-medium px-5 py-2.5 rounded-full text-sm shadow-sm">
            {biz}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- Pricing preview -->
  <section class="py-20 px-4 bg-white">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-14">
        <h2 class="text-3xl md:text-4xl font-black text-[#0A1628] mb-4">Simple, Transparent Pricing</h2>
        <p class="text-gray-500 text-lg">One flat fee. No per-call charges. No surprises.</p>
      </div>
      <div class="max-w-md mx-auto">
        <div class="border-2 border-[#2D6FE8] rounded-2xl p-8 relative shadow-xl">
          <span class="absolute -top-3 left-1/2 -translate-x-1/2 bg-[#2D6FE8] text-white text-xs font-black px-4 py-1 rounded-full">EVERYTHING INCLUDED</span>
          <p class="text-sm font-semibold text-[#2D6FE8] uppercase tracking-wider mb-2">Full Access</p>
          <p class="text-4xl font-black text-[#0A1628] mb-1">$199<span class="text-lg font-normal text-gray-400">/mo</span></p>
          <p class="text-sm text-gray-400 mb-6">Flat rate — no per-call fees, ever</p>
          <ul class="space-y-3 text-gray-600 text-sm mb-8">
            <li class="flex gap-2"><span class="text-[#2D6FE8] font-bold">✓</span> AI answers every call, 24/7</li>
            <li class="flex gap-2"><span class="text-[#2D6FE8] font-bold">✓</span> Real-time lead scoring</li>
            <li class="flex gap-2"><span class="text-[#2D6FE8] font-bold">✓</span> Instant hot-lead alerts</li>
            <li class="flex gap-2"><span class="text-[#2D6FE8] font-bold">✓</span> Full lead dashboard & transcripts</li>
            <li class="flex gap-2"><span class="text-[#2D6FE8] font-bold">✓</span> Monthly performance reports</li>
          </ul>
          <a href="/contact" class="block text-center bg-[#2D6FE8] text-white font-bold py-3 rounded-lg hover:bg-blue-600 transition-colors">
            Get Started
          </a>
        </div>
      </div>
      <p class="text-center text-gray-400 text-sm mt-8">No long-term contracts. Cancel anytime. <a href="/services" class="text-[#2D6FE8] font-semibold hover:underline">Full plan details →</a></p>
    </div>
  </section>


</Layout>
