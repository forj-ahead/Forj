---
import Layout from '../layouts/Layout.astro';

const services = [
  {
    title: "Professional Website",
    desc: "A fast, mobile-first site built to convert visitors into calls. Custom design, not a template. Hosted and maintained for you.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#2D6FE8" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>`
  },
  {
    title: "Google & Local SEO",
    desc: "We manage your Google Business Profile, local citations, and SEO so you show up when customers search for what you do.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#2D6FE8" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>`
  },
  {
    title: "Reviews & Reputation",
    desc: "Automated review requests, monitoring, and responses. More 5-star reviews means more trust and more calls.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#2D6FE8" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>`
  },
  {
    title: "Google Ads",
    desc: "Targeted ads that put your business in front of customers who are ready to hire right now. No wasted spend.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#2D6FE8" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>`
  },
  {
    title: "Monthly Reporting",
    desc: "Know exactly how your online presence is performing — calls, clicks, impressions — in a clear monthly dashboard.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#2D6FE8" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>`
  },
  {
    title: "Real Support",
    desc: "A real person who knows your business. Not a ticket queue. Fast responses, no runaround.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#2D6FE8" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`
  },
];

const industries = ["Roofers","HVAC","Landscapers","Plumbers","Electricians","Movers","Painters","Cleaners","Contractors","Restaurants","Auto Repair","Pest Control","Tree Services","Pressure Washing","Concrete & Masonry"];
---

<Layout
  title="Forj — More Calls. More Customers. Less Hassle."
  description="Forj builds and manages your entire online presence so local businesses get found, get called, and keep growing. Washington DC, Northern Virginia, Maryland."
>

  <!-- Hero -->
  <section class="bg-[#0A1628] text-white pt-20 pb-0 md:pt-28 px-4 overflow-hidden">
    <div class="max-w-6xl mx-auto">
      <div class="flex flex-col md:flex-row md:items-center gap-12 md:gap-16">

        <!-- Left: Text -->
        <div class="md:w-1/2 pb-12 md:pb-20">
          <div class="inline-block bg-[#2D6FE8]/20 text-[#2D6FE8] text-sm font-semibold px-4 py-1.5 rounded-full mb-8 border border-[#2D6FE8]/30">
            Washington DC · Northern Virginia · Maryland
          </div>
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-black leading-tight mb-6">
            More Calls.<br />More Customers.<br /><span class="text-[#2D6FE8]">Less Hassle.</span>
          </h1>
          <p class="text-white/70 text-lg md:text-xl mb-10 leading-relaxed">
            Forj builds and manages your entire online presence so local businesses get found, get called, and keep growing. You focus on the work. We handle everything else.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="/contact" class="bg-[#2D6FE8] text-white font-black text-lg px-8 py-4 rounded-lg hover:bg-blue-600 transition-colors shadow-xl text-center">
              Get a Free Mockup →
            </a>
            <a href="/services" class="border border-white/30 text-white font-semibold text-lg px-8 py-4 rounded-lg hover:bg-white/10 transition-colors text-center">
              See Pricing
            </a>
          </div>
        </div>

        <!-- Right: Browser mockup -->
        <div class="md:w-1/2 flex items-end justify-center md:justify-end">
          <div class="w-full max-w-lg">
            <!-- Browser chrome -->
            <div class="bg-[#1a2a44] rounded-t-xl border border-white/10 px-4 py-3 flex items-center gap-2">
              <div class="flex gap-1.5">
                <div class="w-3 h-3 rounded-full bg-red-400/70"></div>
                <div class="w-3 h-3 rounded-full bg-yellow-400/70"></div>
                <div class="w-3 h-3 rounded-full bg-green-400/70"></div>
              </div>
              <div class="flex-1 mx-3 bg-white/10 rounded-md px-3 py-1 text-xs text-white/40 font-mono">
                acmeroofing.com
              </div>
            </div>
            <!-- Browser content -->
            <div class="bg-white rounded-b-xl overflow-hidden shadow-2xl border border-white/10 border-t-0">
              <!-- Mock site nav -->
              <div class="bg-[#0A1628] px-5 py-3 flex items-center justify-between">
                <div class="text-white font-black text-sm">ACME ROOFING</div>
                <div class="hidden sm:flex gap-4 text-white/60 text-xs">
                  <span>Services</span><span>About</span><span>Contact</span>
                </div>
                <div class="bg-[#2D6FE8] text-white text-xs font-bold px-3 py-1.5 rounded">Call Now</div>
              </div>
              <!-- Mock hero -->
              <div class="bg-gradient-to-br from-slate-700 to-slate-900 px-6 py-8 text-white">
                <div class="text-xs text-white/50 uppercase tracking-widest mb-2">Washington DC's #1 Roofer</div>
                <div class="text-xl font-black mb-2 leading-tight">Licensed, Insured &<br />Ready to Help</div>
                <div class="text-white/60 text-xs mb-4">Serving DC, NoVA & Maryland since 2008</div>
                <div class="flex gap-2">
                  <div class="bg-[#2D6FE8] text-white text-xs font-bold px-4 py-2 rounded">Free Estimate</div>
                  <div class="border border-white/30 text-white text-xs px-4 py-2 rounded">Our Work</div>
                </div>
              </div>
              <!-- Mock services -->
              <div class="bg-gray-50 px-6 py-5">
                <div class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-3">Our Services</div>
                <div class="grid grid-cols-3 gap-2">
                  {["Roof Repair","New Roofs","Gutters"].map(s => (
                    <div class="bg-white rounded-lg p-3 text-center shadow-sm border border-gray-100">
                      <div class="text-lg mb-1">🏠</div>
                      <div class="text-xs font-semibold text-gray-700">{s}</div>
                    </div>
                  ))}
                </div>
              </div>
              <!-- Mock reviews -->
              <div class="bg-white px-6 py-4 border-t border-gray-100">
                <div class="flex items-center gap-2 mb-2">
                  <div class="text-yellow-400 text-sm">★★★★★</div>
                  <div class="text-xs font-bold text-gray-700">4.9 · 127 reviews</div>
                </div>
                <div class="text-xs text-gray-400 italic">"Best roofer in DC. Fast, clean, and fairly priced."</div>
              </div>
            </div>
            <!-- Glow effect -->
            <div class="h-6 bg-gradient-to-b from-[#2D6FE8]/20 to-transparent rounded-b-xl blur-sm -mt-1"></div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Social proof bar -->
  <section class="bg-white border-b border-gray-100 py-6 px-4">
    <div class="max-w-5xl mx-auto flex flex-wrap justify-center gap-6 md:gap-10 text-sm text-gray-500 font-medium">
      <span>✓ No long-term contracts</span>
      <span>✓ Done-for-you setup</span>
      <span>✓ Live in 2 weeks</span>
      <span>✓ DC/NoVA/MD local team</span>
      <span>✓ Cancel anytime</span>
    </div>
  </section>

  <!-- What we do -->
  <section class="py-20 px-4 bg-white">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-14">
        <h2 class="text-3xl md:text-4xl font-black text-[#0A1628] mb-4">Your Entire Online Presence. Handled.</h2>
        <p class="text-gray-500 text-lg max-w-xl mx-auto">One team. One monthly fee. Everything you need to get found online and turn clicks into calls.</p>
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        {services.map(item => (
          <div class="bg-gray-50 rounded-2xl p-7 hover:shadow-md transition-shadow">
            <div class="mb-4" set:html={item.icon} />
            <h3 class="text-xl font-bold text-[#0A1628] mb-2">{item.title}</h3>
            <p class="text-gray-500 leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Who we serve -->
  <section class="py-20 px-4 bg-gray-50">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-14">
        <h2 class="text-3xl md:text-4xl font-black text-[#0A1628] mb-4">Built for Local Service Businesses</h2>
        <p class="text-gray-500 text-lg">If customers need to find you to hire you, Forj is for you.</p>
      </div>
      <div class="flex flex-wrap justify-center gap-3">
        {industries.map(biz => (
          <span class="bg-white border border-gray-200 text-gray-700 font-medium px-5 py-2.5 rounded-full text-sm shadow-sm">
            {biz}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- Pricing preview -->
  <section class="py-20 px-4 bg-white">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-14">
        <h2 class="text-3xl md:text-4xl font-black text-[#0A1628] mb-4">Simple, Transparent Pricing</h2>
        <p class="text-gray-500 text-lg">No surprises. No nickel-and-diming. Everything included.</p>
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="border border-gray-200 rounded-2xl p-8">
          <p class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-2">Starter</p>
          <p class="text-4xl font-black text-[#0A1628] mb-1">$179<span class="text-lg font-normal text-gray-400">/mo</span></p>
          <p class="text-sm text-gray-400 mb-6">+ $500 setup</p>
          <ul class="space-y-3 text-gray-600 text-sm mb-8">
            <li class="flex gap-2"><span class="text-[#2D6FE8] font-bold">✓</span> Custom website</li>
            <li class="flex gap-2"><span class="text-[#2D6FE8] font-bold">✓</span> Hosting & maintenance</li>
            <li class="flex gap-2"><span class="text-[#2D6FE8] font-bold">✓</span> Basic SEO</li>
            <li class="flex gap-2"><span class="text-[#2D6FE8] font-bold">✓</span> SSL & security</li>
          </ul>
          <a href="/contact" class="block text-center border-2 border-[#0A1628] text-[#0A1628] font-bold py-3 rounded-lg hover:bg-[#0A1628] hover:text-white transition-colors">
            Get Started
          </a>
        </div>
        <div class="border-2 border-[#2D6FE8] rounded-2xl p-8 relative shadow-xl">
          <span class="absolute -top-3 left-1/2 -translate-x-1/2 bg-[#2D6FE8] text-white text-xs font-black px-4 py-1 rounded-full">MOST POPULAR</span>
          <p class="text-sm font-semibold text-[#2D6FE8] uppercase tracking-wider mb-2">Growth</p>
          <p class="text-4xl font-black text-[#0A1628] mb-1">$399<span class="text-lg font-normal text-gray-400">/mo</span></p>
          <p class="text-sm text-gray-400 mb-6">+ $750 setup</p>
          <ul class="space-y-3 text-gray-600 text-sm mb-8">
            <li class="flex gap-2"><span class="text-[#2D6FE8] font-bold">✓</span> Everything in Starter</li>
            <li class="flex gap-2"><span class="text-[#2D6FE8] font-bold">✓</span> Google Business Profile</li>
            <li class="flex gap-2"><span class="text-[#2D6FE8] font-bold">✓</span> Local SEO</li>
            <li class="flex gap-2"><span class="text-[#2D6FE8] font-bold">✓</span> Review management</li>
          </ul>
          <a href="/contact" class="block text-center bg-[#2D6FE8] text-white font-bold py-3 rounded-lg hover:bg-blue-600 transition-colors">
            Get Started
          </a>
        </div>
        <div class="border border-gray-200 rounded-2xl p-8 bg-[#0A1628] text-white">
          <p class="text-sm font-semibold text-white/50 uppercase tracking-wider mb-2">Pro</p>
          <p class="text-4xl font-black mb-1">$799<span class="text-lg font-normal text-white/50">/mo</span></p>
          <p class="text-sm text-white/40 mb-6">+ $1,000 setup</p>
          <ul class="space-y-3 text-white/80 text-sm mb-8">
            <li class="flex gap-2"><span class="text-[#2D6FE8] font-bold">✓</span> Everything in Growth</li>
            <li class="flex gap-2"><span class="text-[#2D6FE8] font-bold">✓</span> Google Ads management</li>
            <li class="flex gap-2"><span class="text-[#2D6FE8] font-bold">✓</span> Review automation</li>
            <li class="flex gap-2"><span class="text-[#2D6FE8] font-bold">✓</span> Monthly dashboard</li>
          </ul>
          <a href="/contact" class="block text-center border-2 border-white/30 text-white font-bold py-3 rounded-lg hover:bg-white/10 transition-colors">
            Get Started
          </a>
        </div>
      </div>
      <p class="text-center text-gray-400 text-sm mt-8">All plans include a free mockup before you commit. <a href="/services" class="text-[#2D6FE8] font-semibold hover:underline">Full plan details →</a></p>
    </div>
  </section>


</Layout>
