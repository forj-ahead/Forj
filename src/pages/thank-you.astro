---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Thanks! — Forj"
  description="We received your request and will be in touch within 1 business day."
>
  <section class="bg-[#0A1628] text-white py-28 px-4 min-h-[60vh] flex items-center">
    <div class="max-w-2xl mx-auto text-center">
      <div class="text-6xl mb-6">✅</div>
      <h1 class="text-4xl md:text-5xl font-black mb-4">You're all set!</h1>
      <p class="text-white/70 text-xl mb-10">We got your request. We'll review your business and be in touch within 1 business day to get your AI agent set up.</p>
      <a href="/" class="inline-block bg-[#2D6FE8] text-white font-black text-lg px-8 py-4 rounded-lg hover:bg-blue-600 transition-colors">
        Back to Home
      </a>
    </div>
  </section>
</Layout>
